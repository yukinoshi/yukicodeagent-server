            {
              "name": "noteId",
              "type": "string"
            }
          ]
        }
      ],
      "dataDependencies": ["ReadingNote"],
      "shadcnComponent": "Card"
    },
    {
      "componentId": "BookmarksList",
      "originalId": "BookmarksList",
      "type": "Card",
      "description": "书签列表，展示小说的书签",
      "props": [
        {
          "name": "bookmarks",
          "type": "Bookmark[]",
          "description": "书签列表",
          "required": true
        },
        {
          "name": "novelId",
          "type": "string",
          "description": "关联的小说ID",
          "required": true
        }
      ],
      "events": [
        {
          "name": "onAddBookmark",
          "description": "点击添加新书签",
          "parameters": [
            {
              "name": "novelId",
              "type": "string"
            }
          ]
        },
        {
          "name": "onDeleteBookmark",
          "description": "点击删除书签",
          "parameters": [
            {
              "name": "bookmarkId",
              "type": "string"
            }
          ]
        },
        {
          "name": "onNavigateToBookmark",
          "description": "点击跳转到书签位置",
