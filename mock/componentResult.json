{
  "components": [
    {
      "componentId": "NovelSearchInput",
      "originalId": "SearchInput",
      "type": "Input",
      "description": "搜索小说组件，支持实时搜索和搜索建议",
      "props": [
        {
          "name": "placeholder",
          "type": "string",
          "description": "输入框占位符文本",
          "required": false
        },
        {
          "name": "value",
          "type": "string",
          "description": "当前搜索关键词",
          "required": false
        },
        {
          "name": "className",
          "type": "string",
          "description": "自定义CSS类名",
          "required": false
        }
      ],
      "events": [
        {
          "name": "onSearch",
          "description": "用户执行搜索时触发",
          "parameters": [
            {
              "name": "keyword",
              "type": "string"
            }
          ]
        },
        {
          "name": "onChange",
          "description": "搜索关键词变化时触发",
          "parameters": [
            {
              "name": "value",
              "type": "string"
            }
          ]
        }
      ],
      "dataDependencies": ["Novel"],
      "shadcnComponent": "Input"
    },
    {
      "componentId": "AddNovelButton",
      "originalId": "AddNovelButton",
      "type": "Button",
      "description": "添加新小说按钮，触发添加小说表单",
      "props": [
        {
          "name": "variant",
          "type": "'default' | 'outline' | 'secondary' | 'ghost' | 'link'",
          "description": "按钮变体样式",
          "required": false
        },
        {
          "name": "size",
          "type": "'default' | 'sm' | 'lg' | 'icon'",
          "description": "按钮尺寸",
          "required": false
        },
        {
          "name": "className",
          "type": "string",
          "description": "自定义CSS类名",
          "required": false
        }
      ],
      "events": [
        {
          "name": "onClick",
          "description": "点击按钮时触发添加小说操作",
          "parameters": []
        }
      ],
      "dataDependencies": ["Novel"],
      "shadcnComponent": "Button"
    },
    {
      "componentId": "NovelListTable",
      "originalId": "NovelTable",
      "type": "Table",
      "description": "小说列表表格，展示所有收藏的小说，支持查看详情、编辑和删除",
      "props": [
        {
          "name": "novels",
          "type": "Novel[]",
          "description": "小说数据列表",
          "required": true
        },
        {
          "name": "loading",
          "type": "boolean",
          "description": "数据加载状态",
          "required": false
        },
        {
          "name": "emptyMessage",
          "type": "string",
          "description": "空数据时显示的提示信息",
          "required": false
        }
      ],
      "events": [
        {
          "name": "onViewDetail",
          "description": "点击查看小说详情",
          "parameters": [
            {
              "name": "novel",
              "type": "Novel"
            }
          ]
        },
        {
          "name": "onEdit",
          "description": "点击编辑小说",
          "parameters": [
            {
              "name": "novel",
              "type": "Novel"
            }
          ]
        },
        {
          "name": "onDelete",
          "description": "点击删除小说",
          "parameters": [
            {
              "name": "novelId",
              "type": "string"
            }
          ]
        },
        {
          "name": "onStartReading",
          "description": "点击开始阅读",
          "parameters": [
            {
              "name": "novel",
              "type": "Novel"
            }
          ]
        }
      ],
      "dataDependencies": ["Novel"],
      "shadcnComponent": "Table"
    },
    {
      "componentId": "NovelFilterPanel",
      "originalId": "FilterPanel",
      "type": "Card",
      "description": "小说筛选面板，按分类、状态等条件筛选小说",
      "props": [
        {
          "name": "categories",
          "type": "Category[]",
          "description": "可用的分类列表",
          "required": true
        },
        {
          "name": "selectedCategory",
          "type": "string | null",
          "description": "当前选中的分类ID",
          "required": false
        },
        {
          "name": "selectedStatus",
          "type": "string | null",
          "description": "当前选中的阅读状态",
          "required": false
        }
      ],
      "events": [
        {
          "name": "onCategoryChange",
          "description": "分类筛选条件变化",
          "parameters": [
            {
              "name": "categoryId",
              "type": "string | null"
            }
          ]
        },
        {
          "name": "onStatusChange",
          "description": "状态筛选条件变化",
          "parameters": [
            {
              "name": "status",
              "type": "string | null"
            }
          ]
        },
        {
          "name": "onReset",
          "description": "重置所有筛选条件",
          "parameters": []
        }
      ],
      "dataDependencies": ["Category", "Novel"],
      "shadcnComponent": "Card"
    },
    {
      "componentId": "NovelInfoCard",
      "originalId": "NovelInfoCard",
      "type": "Card",
      "description": "小说信息展示卡片，显示小说基本信息",
      "props": [
        {
          "name": "novel",
          "type": "Novel",
          "description": "小说数据",
          "required": true
        },
        {
          "name": "showActions",
          "type": "boolean",
          "description": "是否显示操作按钮",
          "required": false
        }
      ],
      "events": [
        {
          "name": "onEdit",
          "description": "点击编辑小说信息",
          "parameters": [
            {
              "name": "novel",
              "type": "Novel"
            }
          ]
        }
      ],
      "dataDependencies": ["Novel"],
      "shadcnComponent": "Card"
    },
    {
      "componentId": "ReadingProgressCard",
      "originalId": "ReadingProgressCard",
      "type": "Card",
      "description": "阅读进度卡片，显示阅读进度和进度控制",
      "props": [
        {
          "name": "novel",
          "type": "Novel",
          "description": "小说数据，包含阅读进度信息",
          "required": true
        },
        {
          "name": "showStartButton",
          "type": "boolean",
          "description": "是否显示开始阅读按钮",
          "required": false
        }
      ],
      "events": [
        {
          "name": "onStartReading",
          "description": "点击开始阅读",
          "parameters": [
            {
              "name": "novel",
              "type": "Novel"
            }
          ]
        },
        {
          "name": "onProgressChange",
          "description": "阅读进度变化",
          "parameters": [
            {
              "name": "pageNumber",
              "type": "number"
            }
          ]
        }
      ],
      "dataDependencies": ["Novel"],
      "shadcnComponent": "Card"
    },
    {
      "componentId": "ReadingNotesList",
      "originalId": "RecentNotes",
      "type": "Card",
      "description": "阅读笔记列表，展示小说的相关笔记",
      "props": [
        {
          "name": "notes",
          "type": "ReadingNote[]",
          "description": "笔记列表",
          "required": true
        },
        {
          "name": "novelId",
          "type": "string",
          "description": "关联的小说ID",
          "required": true
        },
        {
          "name": "maxItems",
          "type": "number",
          "description": "最大显示数量",
          "required": false
        }
      ],
      "events": [
        {
          "name": "onAddNote",
          "description": "点击添加新笔记",
          "parameters": [
            {
              "name": "novelId",
              "type": "string"
            }
          ]
        },
        {
          "name": "onEditNote",
          "description": "点击编辑笔记",
          "parameters": [
            {
              "name": "note",
              "type": "ReadingNote"
            }
          ]
        },
        {
          "name": "onDeleteNote",
          "description": "点击删除笔记",
