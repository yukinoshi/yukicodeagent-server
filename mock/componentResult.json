            {
              "name": "bookmark",
              "type": "Bookmark"
            }
          ]
        }
      ],
      "dataDependencies": ["Bookmark"],
      "shadcnComponent": "Card"
    },
    {
      "componentId": "NovelForm",
      "originalId": "NovelFormCard",
      "type": "Form",
      "description": "小说信息表单，用于添加或编辑小说",
      "props": [
        {
          "name": "novel",
          "type": "Partial<Novel> | null",
          "description": "编辑时的小说数据，新增时为null",
          "required": false
        },
        {
          "name": "categories",
          "type": "Category[]",
          "description": "可用的分类列表",
          "required": true
        },
        {
          "name": "loading",
          "type": "boolean",
          "description": "表单提交加载状态",
          "required": false
        }
      ],
      "events": [
        {
          "name": "onSubmit",
          "description": "表单提交",
          "parameters": [
            {
              "name": "novelData",
              "type": "Partial<Novel>"
            }
          ]
        },
        {
          "name": "onCancel",
          "description": "取消表单操作",
          "parameters": []
        }
      ],
      "dataDependencies": ["Novel", "Category"],
      "shadcnComponent": "Form"
    },
    {
      "componentId": "ReadingNoteForm",
      "originalId": "NoteFormCard",
      "type": "Form",
      "description": "阅读笔记表单，用于添加或编辑阅读笔记",
      "props": [
        {
          "name": "note",
          "type": "Partial<ReadingNote> | null",
          "description": "编辑时的笔记数据，新增时为null",
          "required": false
        },
        {
          "name": "novelId",
          "type": "string",
          "description": "关联的小说ID",
          "required": true
        },
        {
          "name": "maxPage",
          "type": "number",
          "description": "小说的最大页码，用于页码验证",
          "required": false
        },
        {
          "name": "loading",
          "type": "boolean",
          "description": "表单提交加载状态",
          "required": false
        }
      ],
      "events": [
        {
          "name": "onSubmit",
          "description": "表单提交",
          "parameters": [
            {
              "name": "noteData",
              "type": "Partial<ReadingNote>"
            }
          ]
        },
        {
          "name": "onCancel",
          "description": "取消表单操作",
          "parameters": []
        }
      ],
      "dataDependencies": ["ReadingNote"],
      "shadcnComponent": "Form"
    },
    {
      "componentId": "ReadingToolbar",
      "originalId": "ReadingToolbar",
      "type": "Toolbar",
      "description": "阅读工具栏，提供阅读控制功能",
      "props": [
        {
          "name": "novel",
          "type": "Novel",
          "description": "当前阅读的小说",
          "required": true
        },
        {
          "name": "currentPage",
          "type": "number",
          "description": "当前阅读页码",
          "required": true
        }
      ],
      "events": [
        {
          "name": "onSaveProgress",
          "description": "保存阅读进度",
          "parameters": [
            {
              "name": "pageNumber",
              "type": "number"
            }
          ]
        },
        {
          "name": "onAddNote",
          "description": "添加阅读笔记",
          "parameters": [
            {
              "name": "pageNumber",
              "type": "number"
            }
          ]
        },
        {
          "name": "onPrevPage",
          "description": "跳转到上一页",
          "parameters": []
        },
        {
          "name": "onNextPage",
          "description": "跳转到下一页",
          "parameters": []
        },
        {
          "name": "onSettingsOpen",
          "description": "打开阅读设置",
          "parameters": []
        }
      ],
      "dataDependencies": ["Novel"],
      "shadcnComponent": "Toolbar"
    },
    {
      "componentId": "ReadingProgressSlider",
      "originalId": "ProgressSlider",
      "type": "Slider",
      "description": "阅读进度滑块，控制阅读进度",
      "props": [
        {
          "name": "value",
          "type": "number",
          "description": "当前进度值（页码）",
          "required": true
        },
        {
          "name": "min",
          "type": "number",
          "description": "最小页码",
          "required": false
        },
        {
          "name": "max",
          "type": "number",
          "description": "最大页码（小说总页数）",
          "required": true
        },
        {
          "name": "step",
          "type": "number",
          "description": "步长",
          "required": false
        }
      ],
      "events": [
        {
          "name": "onValueChange",
          "description": "进度值变化",
          "parameters": [
            {
              "name": "value",
              "type": "number"
            }
          ]
        },
        {
          "name": "onValueCommit",
          "description": "进度值确认（用户释放滑块）",
          "parameters": [
            {
              "name": "value",
              "type": "number"
            }
          ]
        }
      ],
      "dataDependencies": ["Novel"],
      "shadcnComponent": "Slider"
    },
