{
  "pages": [
    {
      "pageId": "LibraryDashboard",
      "route": "/",
      "description": "小说库概览页面，展示所有小说收藏和阅读统计",
      "layout": "dashboard-shell",
      "sections": [
        {
          "sectionId": "sidebar",
          "role": "navigation",
          "layout": "flex-col",
          "title": "导航菜单",
          "components": [
            {
              "id": "MainSidebar",
              "type": "Sidebar",
              "label": "主侧边栏",
              "bindDataModel": "",
              "bindBehavior": []
            },
            {
              "id": "NavMenu",
              "type": "NavigationMenu",
              "label": "导航菜单",
              "bindDataModel": "",
              "bindBehavior": ["browseNovels", "viewStatistics"]
            }
          ]
        },
        {
          "sectionId": "header",
          "role": "navigation",
          "layout": "flex-row",
          "title": "顶部导航栏",
          "components": [
            {
              "id": "MainNavbar",
              "type": "Navbar",
              "label": "顶部导航栏",
              "bindDataModel": "",
              "bindBehavior": []
            },
            {
              "id": "SearchInput",
              "type": "Input",
              "label": "搜索小说",
              "bindDataModel": "Novel",
              "bindBehavior": ["searchNovels"]
            },
            {
              "id": "UserAvatar",
              "type": "Avatar",
              "label": "用户头像",
              "bindDataModel": "",
              "bindBehavior": []
            }
          ]
        },
        {
          "sectionId": "content",
          "role": "dashboard",
          "layout": "grid",
          "title": "仪表盘内容区",
          "components": [
            {
              "id": "WelcomeCard",
              "type": "Card",
              "label": "欢迎卡片",
              "bindDataModel": "",
              "bindBehavior": []
            },
            {
              "id": "ReadingStats",
              "type": "Card",
              "label": "阅读统计",
              "bindDataModel": "ReadingSession",
              "bindBehavior": ["viewStatistics"]
            },
            {
              "id": "RecentNovels",
              "type": "Card",
              "label": "最近阅读",
              "bindDataModel": "Novel",
              "bindBehavior": ["browseNovels", "viewNovelDetail"]
            },
            {
              "id": "QuickActions",
              "type": "Card",
              "label": "快速操作",
              "bindDataModel": "",
              "bindBehavior": ["addNovel", "browseNovels"]
            },
            {
              "id": "ReadingProgressChart",
              "type": "Chart",
              "label": "阅读进度图表",
              "bindDataModel": "Novel",
              "bindBehavior": ["viewStatistics"]
            },
            {
              "id": "CategoryOverview",
              "type": "Card",
              "label": "分类概览",
              "bindDataModel": "Category",
              "bindBehavior": ["filterNovels"]
            }
          ]
        }
      ]
    },
    {
