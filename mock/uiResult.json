          "layout": "flex-row",
          "title": "顶部导航栏",
          "components": [
            {
              "id": "MainNavbar",
              "type": "Navbar",
              "label": "顶部导航栏",
              "bindDataModel": "",
              "bindBehavior": []
            },
            {
              "id": "PageTitle",
              "type": "Label",
              "label": "小说收藏",
              "bindDataModel": "",
              "bindBehavior": []
            },
            {
              "id": "SearchInput",
              "type": "Input",
              "label": "搜索小说",
              "bindDataModel": "Novel",
              "bindBehavior": ["searchNovels"]
            },
            {
              "id": "AddNovelButton",
              "type": "Button",
              "label": "添加小说",
              "bindDataModel": "Novel",
              "bindBehavior": ["addNovel"]
            }
          ]
        },
        {
          "sectionId": "content",
          "role": "list",
          "layout": "flex-col",
          "title": "小说列表",
          "components": [
            {
              "id": "FilterPanel",
              "type": "Card",
              "label": "筛选面板",
              "bindDataModel": "Category",
              "bindBehavior": ["filterNovels"]
